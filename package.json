{
  "name": "vue-virtual-keyboard",
  "version": "2.0.0",
  "type": "module",
  "description": "Virtual Keyboard using vue 3x and Microsoft Keyboard Layouts.",
  "author": "Geirr Winnem <geirr@winnem.tech>",
  "funding": {
    "type": "paypal",
    "url": "https://paypal.me/gwinnem"
  },
  "license": "MIT",
  "keywords": [
    "Virtual keyboard",
    "Kiosk Keyboard",
    "Touch keyboard",
    "Screen Keyboard",
    "On Screen",
    "Keyboard",
    "Virtual",
    "Vue 3x",
    "Vue",
    "Typescript"
  ],
  "main": "dist/vue-virtual-keyboard.umd.js",
  "module": "dist/vue-virtual-keyboard.es.js",
  "types": "dist/types/lib/index.d.ts",
  "files": [
    "dist",
    "NOTICE.md"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/types/lib/index.d.ts",
      "import": "./dist/vue-virtual-keyboard.es.js",
      "require": "./dist/vue-virtual-keyboard.umd.js"
    },
    "./style.css": "./dist/style.css"
  },
  "homepage": "https://vue-virtual-keyboard.winnem.tech",
  "repository": {
    "type": "git",
    "url": "https://github.com/gwinnem/vue-virtual-keyboard.git"
  },
  "bugs": {
    "url": "https://github.com/gwinnem/https://github.com/gwinnem/vue-virtual-keyboard/issues"
  },
  "scripts": {
    "prepare": "husky install",
    "dev": "vite --host",
    "build:all": "vite build && npm run build:types && npm pack",
    "build:only": "vite build",
    "size-check": "node scripts/check-bundle-size.mjs",
    "build:types": "vue-tsc --project tsconfig.json --declaration --emitDeclarationOnly --outDir ./dist",
    "typecheck": "vue-tsc --project tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.{js,ts,vue}\" \"e2e/**/*.ts\" \"playwright.config.ts\" \"scripts/**/*.mjs\" \"sandbox/**/*.vue\" --color",
    "lint:fix": "eslint \"src/**/*.{js,ts,vue}\" \"e2e/**/*.ts\" \"playwright.config.ts\" \"sandbox/**/*.vue\" --fix --color",
    "lint:style": "npx stylelint src/**/*.{scss,vue} sandbox/**/*.vue --no-fix --color",
    "lint:markup": "vue-tsc -noEmit",
    "format": "eslint \"src/**/*.{js,ts,vue}\" \"e2e/**/*.ts\" \"playwright.config.ts\" \"scripts/**/*.mjs\" \"sandbox/**/*.vue\" --fix && stylelint \"src/**/*.{scss,vue}\" \"sandbox/**/*.vue\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "e2e:install": "playwright install --with-deps",
    "e2e:run": "playwright test --grep-invert @visual",
    "e2e:visual": "playwright test --grep @visual",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "docs:dev": "vitepress dev vitepress-docs",
    "docs:build": "vitepress build vitepress-docs",
    "docs:preview": "vitepress preview vitepress-docs"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@stylistic/eslint-plugin": "^2.13.0",
    "@types/node": "^22.20.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^3.2.7",
    "@vitest/ui": "^3.2.7",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-import-quotes": "^0.0.1",
    "eslint-plugin-vue": "^9.8.0",
    "husky": "^8.0.3",
    "jsdom": "^21.1.0",
    "lint-staged": "^16.4.0",
    "sass": "^1.93.2",
    "stylelint": "^14.8.5",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-config-recommended-vue": "^1.4.0",
    "stylelint-config-standard-scss": "^3.0.0",
    "stylelint-order": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.7",
    "vue": "^3.2.0",
    "vue-tsc": "^2.2.12"
  },
  "lint-staged": {
    "*.{ts,vue}": "eslint --fix",
    "*.{css,scss,vue}": "stylelint --fix"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "overrides": {
    "vite": "^6.4.3"
  },
  "peerDependencies": {
    "vue": "^3.2.25"
  },
  "engines": {
    "node": ">=20.17.0"
  }
}
