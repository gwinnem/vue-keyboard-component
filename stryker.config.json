{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "mutate": [
    "src/core/helpers/LayoutHelper.ts",
    "src/core/helpers/RtlHelper.ts",
    "src/lib/components/ThemeSwitcher.vue",
    "src/lib/components/KeyboardButton.vue",
    "src/lib/components/Keyboard.vue"
  ],
  "reporters": ["clear-text", "progress", "html"],
  "coverageAnalysis": "perTest",
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 60
  }
}
